  "keyFeatures": [
    "Auto-detect locale files in any public GitHub repository",
    "Generate localization health reports with coverage stats",
    "Identify missing, untranslated, and orphan translation keys",
    "One-click fix with Lingo.dev integration",
    "Shareable report URLs with social preview cards",
    "Support for JSON, YAML, and .po translation files",
    "Visual dashboard with per-locale breakdowns",
    "GitHub OAuth authentication for private repos"
  ],
  "publicApiSurface": [
    "POST /api/scan - Scan a GitHub repository for translation issues",
    "parseRepoUrl(input) - Parse GitHub URLs or owner/repo strings",
    "getRepoInfo(owner, repo) - Fetch repository metadata",
    "getRepoTree(owner, repo, branch) - Get full file tree",
    "getFileContent(owner, repo, branch, path) - Fetch raw file content",
    "detectLocaleFiles(tree) - Auto-detect translation files",
    "parseLocaleFile(content, path) - Parse locale files to key maps",
    "generateReport(sourceLocale, keyMaps) - Generate health report"
  ]
}
